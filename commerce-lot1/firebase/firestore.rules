rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function rolePath(tenantId) {
      return /databases/$(database)/documents/tenants/$(tenantId)/roleBindings/$(request.auth.uid);
    }

    function roleDoc(tenantId) {
      return get(rolePath(tenantId));
    }

    function roleData(tenantId) {
      return roleDoc(tenantId).data;
    }

    function hasRoleDoc(tenantId) {
      return isSignedIn() && exists(rolePath(tenantId));
    }

    function roleName(tenantId) {
      return hasRoleDoc(tenantId) ? roleData(tenantId).role : null;
    }

    function userStoreIds(tenantId) {
      return hasRoleDoc(tenantId) && roleData(tenantId).storeIds is list
        ? roleData(tenantId).storeIds
        : [];
    }

    function isOwner(tenantId) {
      return roleName(tenantId) == 'owner';
    }

    function isManager(tenantId) {
      return roleName(tenantId) == 'manager';
    }

    function isEmployee(tenantId) {
      return roleName(tenantId) == 'employee';
    }

    function canReadInternal(tenantId) {
      return isOwner(tenantId) || isManager(tenantId) || isEmployee(tenantId);
    }

    function canWriteCatalog(tenantId) {
      return isOwner(tenantId) || isManager(tenantId);
    }

    function canWriteSales(tenantId) {
      return isOwner(tenantId) || isManager(tenantId) || isEmployee(tenantId);
    }

    function isAllowedStore(tenantId, storeId) {
      return isOwner(tenantId) || storeId in userStoreIds(tenantId);
    }

    function isPublicProduct() {
      return resource != null
        && resource.data.isPublished == true
        && resource.data.isActive == true;
    }

    function isValidTenantPayload() {
      return request.resource.data.ownerUid is string
        && request.resource.data.name is string;
    }

    match /tenants/{tenantId} {
      allow read: if canReadInternal(tenantId);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerUid && isValidTenantPayload();
      allow update, delete: if isOwner(tenantId);

      match /settings/{settingId} {
        allow read: if canReadInternal(tenantId);
        allow write: if isOwner(tenantId) || isManager(tenantId);
      }

      match /stores/{storeId} {
        allow read: if canReadInternal(tenantId);
        allow create, update: if canWriteCatalog(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /categories/{categoryId} {
        allow read: if true;
        allow create, update: if canWriteCatalog(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /products/{productId} {
        allow read: if isPublicProduct() || canReadInternal(tenantId);
        allow create, update: if canWriteCatalog(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /inventory/{inventoryId} {
        allow read: if canReadInternal(tenantId);
        allow create, update: if canWriteCatalog(tenantId)
          && request.resource.data.storeId is string
          && isAllowedStore(tenantId, request.resource.data.storeId);
        allow delete: if isOwner(tenantId);
      }

      match /customers/{customerId} {
        allow read, create, update: if canReadInternal(tenantId);
        allow delete: if isOwner(tenantId) || isManager(tenantId);
      }

      match /suppliers/{supplierId} {
        allow read: if canReadInternal(tenantId);
        allow create, update: if canWriteCatalog(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /employees/{employeeId} {
        allow read: if isOwner(tenantId) || isManager(tenantId);
        allow create, update, delete: if isOwner(tenantId);
      }

      match /roleBindings/{uid} {
        allow read: if isOwner(tenantId) || (isSignedIn() && request.auth.uid == uid);
        allow create, update, delete: if isOwner(tenantId);
      }

      match /orders/{orderId} {
        allow create: if request.resource.data.tenantId == tenantId
          && request.resource.data.storeId is string
          && request.resource.data.source in ['storefront', 'employee-pos', 'admin']
          && request.resource.data.status in ['pending', 'confirmed', 'processing', 'ready', 'completed', 'rejected', 'cancelled'];
        allow read: if canReadInternal(tenantId);
        allow update: if canWriteSales(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /sales/{saleId} {
        allow read: if canReadInternal(tenantId);
        allow create: if canWriteSales(tenantId)
          && request.resource.data.tenantId == tenantId
          && request.resource.data.storeId is string
          && isAllowedStore(tenantId, request.resource.data.storeId);
        allow update: if isOwner(tenantId) || isManager(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /purchases/{purchaseId} {
        allow read: if canReadInternal(tenantId);
        allow create, update: if canWriteCatalog(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /cashSessions/{sessionId} {
        allow read: if canReadInternal(tenantId);
        allow create, update: if canWriteSales(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /inventoryCounts/{countId} {
        allow read: if canReadInternal(tenantId);
        allow create, update: if canWriteCatalog(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /stockMovements/{movementId} {
        allow read: if canReadInternal(tenantId);
        allow create: if canWriteSales(tenantId) || canWriteCatalog(tenantId);
        allow update, delete: if isOwner(tenantId);
      }

      match /reportsDaily/{reportId} {
        allow read: if canReadInternal(tenantId);
        allow write: if isOwner(tenantId) || isManager(tenantId);
      }

      match /reportsMonthly/{reportId} {
        allow read: if canReadInternal(tenantId);
        allow write: if isOwner(tenantId) || isManager(tenantId);
      }
    }
  }
}
