rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function rolePath(tenantId) { return /databases/$(database)/documents/tenants/$(tenantId)/roleBindings/$(request.auth.uid); }
    function hasRoleDoc(tenantId) { return isSignedIn() && exists(rolePath(tenantId)); }
    function roleData(tenantId) { return hasRoleDoc(tenantId) ? get(rolePath(tenantId)).data : null; }
    function roleName(tenantId) { return hasRoleDoc(tenantId) ? roleData(tenantId).role : null; }
    function storeIds(tenantId) { return hasRoleDoc(tenantId) && roleData(tenantId).storeIds is list ? roleData(tenantId).storeIds : []; }
    function isOwner(tenantId) { return roleName(tenantId) == 'owner'; }
    function isManager(tenantId) { return roleName(tenantId) == 'manager'; }
    function isEmployee(tenantId) { return roleName(tenantId) == 'employee'; }
    function canReadInternal(tenantId) { return isOwner(tenantId) || isManager(tenantId) || isEmployee(tenantId); }
    function canWriteCatalog(tenantId) { return isOwner(tenantId) || isManager(tenantId); }
    function canWriteSales(tenantId) { return isOwner(tenantId) || isManager(tenantId) || isEmployee(tenantId); }
    function allowedStore(tenantId, storeId) { return isOwner(tenantId) || (storeId in storeIds(tenantId)); }
    function requestedStoreAllowed(tenantId) { return request.resource.data.storeId is string && allowedStore(tenantId, request.resource.data.storeId); }
    function sameTenantWrite(tenantId) { return request.resource.data.tenantId == tenantId; }
    function publicProduct() { return resource.data.isPublished == true && resource.data.isActive == true; }

    match /tenants/{tenantId} {
      allow read: if canReadInternal(tenantId);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerUid;
      allow update, delete: if isOwner(tenantId);

      match /settings/{settingId} {
        allow read: if canReadInternal(tenantId);
        allow write: if canWriteCatalog(tenantId);
      }

      match /stores/{storeId} {
        allow read: if canReadInternal(tenantId);
        allow create, update: if canWriteCatalog(tenantId) && sameTenantWrite(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /categories/{categoryId} {
        allow read: if true;
        allow create, update: if canWriteCatalog(tenantId) && sameTenantWrite(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /products/{productId} {
        allow read: if publicProduct() || canReadInternal(tenantId);
        allow create, update: if canWriteCatalog(tenantId) && sameTenantWrite(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /inventory/{inventoryId} {
        allow read: if canReadInternal(tenantId);
        allow create, update: if canWriteCatalog(tenantId) && sameTenantWrite(tenantId) && requestedStoreAllowed(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /employees/{employeeId} {
        allow read: if isOwner(tenantId) || isManager(tenantId);
        allow create, update, delete: if isOwner(tenantId) && sameTenantWrite(tenantId);
      }

      match /roleBindings/{uid} {
        allow read: if isOwner(tenantId) || (isSignedIn() && request.auth.uid == uid);
        allow create, update, delete: if isOwner(tenantId);
      }

      match /customers/{customerId} {
        allow read, create, update: if canReadInternal(tenantId);
        allow delete: if isOwner(tenantId) || isManager(tenantId);
      }

      match /suppliers/{supplierId} {
        allow read: if canReadInternal(tenantId);
        allow create, update: if canWriteCatalog(tenantId) && sameTenantWrite(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /orders/{orderId} {
        allow create: if request.resource.data.tenantId == tenantId && request.resource.data.storeId is string && request.resource.data.items is list;
        allow read: if canReadInternal(tenantId);
        allow update: if canWriteSales(tenantId) && sameTenantWrite(tenantId) && requestedStoreAllowed(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /sales/{saleId} {
        allow read: if canReadInternal(tenantId);
        allow create: if canWriteSales(tenantId) && sameTenantWrite(tenantId) && requestedStoreAllowed(tenantId);
        allow update: if isOwner(tenantId) || isManager(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /cashSessions/{sessionId} {
        allow read: if canReadInternal(tenantId);
        allow create, update: if canWriteSales(tenantId) && sameTenantWrite(tenantId) && requestedStoreAllowed(tenantId);
        allow delete: if isOwner(tenantId);
      }

      match /stockMovements/{movementId} {
        allow read: if canReadInternal(tenantId);
        allow create: if canWriteSales(tenantId) && sameTenantWrite(tenantId) && requestedStoreAllowed(tenantId);
        allow update, delete: if isOwner(tenantId);
      }
    }
  }
}
